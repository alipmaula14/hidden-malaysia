# ============================================================
# Hidden Malaysia — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Node environment ---
# Set to "production" on Railway; leave blank or "development" locally
NODE_ENV=development

# --- Session secret ---
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# --- Production site URL (Railway / custom domain) ---
# Used to lock CORS to your domain in production.
# Example: https://hidden-malaysia.up.railway.app
# Leave blank during local development.
SITE_URL=

# --- Database (local development) ---
# On Railway the MySQL plugin auto-injects MYSQL* variables below — you don't set these.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=hidden_malaysia

# --- Database (Railway MySQL plugin — auto-injected, do not set manually) ---
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
# MYSQL_URL=
